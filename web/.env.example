# Slice 3 audit agent — server-only secrets. Copy this file to .env.local and fill in
# the real value there. NEVER commit .env.local or the real key.

# OpenRouter API key (https://openrouter.ai/keys). Read only on the server.
OPENROUTER_API_KEY=

# Optional: override the audit model. Default: google/gemini-2.5-flash
AUDIT_MODEL=
